			bus@0 {
				/* set camera gpio direction to output */
				gpio@810c300000 {
					camera-control-output-high {
						gpio-hog;
						output-high;
						gpios = <CAM0_RST_L 0 CAM0_PWDN 0 CAM1_RST_L 0 CAM1_PWDN 0>;//0：高电平有效
						label = "cam0-rst", "cam0-pwdn", "cam1-rst", "cam1-pwdn";
					};
				};
				// pwm-gpio { //TODO 修改上面的宏就行
				// 	compatible = "pwm-gpio";
				// 	status = "okay";
				// 	gpios = <&gpio_main CAM_SYNC GPIO_ACTIVE_LOW>;
