#include <dt-bindings/clock/tegra264-clock.h>
#include <dt-bindings/gpio/tegra264-gpio.h>
//#include <dt-bindings/tegra234-p3737-0000+p3701-0000.h>

/* camera control gpio definitions */
#define CAM0_PWDN	TEGRA264_MAIN_GPIO(V, 1) //l49-pv01
#define CAM0_RST_L	TEGRA264_MAIN_GPIO(V, 2) //l5-pv02
#define CAM1_PWDN	TEGRA264_MAIN_GPIO(Q, 2)//f10-PQ02
#define CAM1_RST_L	TEGRA264_MAIN_GPIO(Q, 3)//f11-PQ03

// #define CAM_SYNC    TEGRA264_MAIN_GPIO(K, 5) 

// #define CAMERA_I2C_MUX_BUS(x) (0x1E + x)
#define JETSON_COMPATIBLE	"nvidia,p3971-0089+p3834-0008", "nvidia,p3971-0050+p3834-0005", "nvidia,p3971-0080+p3834-0008", "nvidia,p3834-0008", "nvidia,tegra264"

/ {
	overlay-name = "Jetson Sensing SG16A_AGTH_G3Y_A1 YUV GMSL2x16";
	jetson-header-name = "Jetson AGX CSI Connector";
	compatible = JETSON_COMPATIBLE;

	fragment@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi {
